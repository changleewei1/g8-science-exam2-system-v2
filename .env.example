# --- 複製為 .env.local 並填入真實值；Vercel 專案設定中亦需相同變數 ---

# Supabase（前端可讀）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase Service Role（僅伺服器／Edge，勿勾選「Expose to browser」）
SUPABASE_SERVICE_ROLE_KEY=

# JWT Session（請使用長隨機字串）
SESSION_SECRET=

# 老師後台登入密鑰（與 SESSION_SECRET 分開）
ADMIN_DASHBOARD_SECRET=

# YouTube Data API（僅本機匯入播放清單 script 需要，網站執行時可不設）
YOUTUBE_API_KEY=

# 若學校只有一個段考範圍，可填 UUID 作為預設導向
NEXT_PUBLIC_DEFAULT_EXAM_SCOPE_ID=

# 選填：正式網址（含 https://），家長分享連結與絕對 URL 會優先使用此值
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# 或僅伺服器可見（不暴露給瀏覽器 bundle）：
# APP_BASE_URL=https://your-app.vercel.app

# 選填：本機或區網用 http 測試時，若 Cookie 無法寫入可設為 1（勿用於正式環境）
# SESSION_COOKIE_INSECURE=1

# --- LINE Messaging API（家長綁定／Webhook）---
# LINE_CHANNEL_SECRET=
# LINE_CHANNEL_ACCESS_TOKEN=
# 本機／ngrok 測試可略過 Webhook 驗簽（僅非 production 有效；正式環境一律驗簽）
# LINE_WEBHOOK_SKIP_VERIFY=true
